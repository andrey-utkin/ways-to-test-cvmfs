.PHONY: pooled.ci.status
pooled.ci.status:
	@ls container-pool/* || true
	@echo -n "STARTED: "; qalc --terse "now - stamptodate($(shell stat -c %Y -- pooled.ci.setup 2>/dev/null))" | grep -v stamptodate || echo
	@echo -n "ENDED: ";   qalc --terse "now - stamptodate($(shell stat -c %Y -- pooled.ci.done  2>/dev/null))" | grep -v stamptodate || echo
	@echo -n "TOOK: ";   qalc --terse "stamptodate($(shell stat -c %Y -- pooled.ci.done 2>/dev/null)) - stamptodate($(shell stat -c %Y -- pooled.ci.setup 2>/dev/null))" | grep -v stamptodate || echo
	@grep -o 'load.*' pooled.ci.done 2>/dev/null || uptime | grep -o 'load.*'
	wc -l tests.list
	ls pooled.ci.*.PASSED 2>/dev/null | wc -l
	ls pooled.ci.*.FAILED 2>/dev/null | wc -l
	@ls -1 pooled.ci.*.FAILED 2>/dev/null || true

