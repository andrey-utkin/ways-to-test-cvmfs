-include *.mk

SHELL := /bin/bash

DIRNAME = $(shell basename $$PWD)
UPDIRNAME = $(shell basename $(shell readlink -f ..))
UPUPDIRNAME = $(shell basename $(shell readlink -f ../..))
# does not match Docker's base image name, no colon
MY_DISTRO := ${DIRNAME}
# docker or podman
ENGINE := ${UPDIRNAME}
NETWORK ?= $(shell if [[ ${ENGINE} == podman ]]; then echo --network=private; else echo --network=bridge; fi)
FLAVOUR := ${UPUPDIRNAME}
LOCAL_GIT_STORE := $(shell readlink -f ../../../cvmfs.git)
GIT_ORIGIN := ${LOCAL_GIT_STORE}
#GIT_ORIGIN := https://github.com/cvmfs/cvmfs.git
GIT_BRANCH ?= devel
IMAGE_NAME := cvmfs-autkin:${MY_DISTRO}
BUILD_IMAGE_NAME ?= ${FLAVOUR}:${MY_DISTRO}-with-build
PACKAGED_INSTALL_DEB_IMAGE_NAME := ${FLAVOUR}:${MY_DISTRO}-with-deb
CONTAINER_NAME := ${FLAVOUR}-${MY_DISTRO}
WORKCOPY_IN_HOST := $(shell readlink -f cvmfs)
CCACHE_IN_HOST := $(shell readlink -f ../../../ccache)
CCACHE_IN_CONTAINER := /root/.ccache
GO_PKG_MOD_IN_HOST := $(shell readlink -f ../../../go_pkg_mod)
GO_PKG_MOD_IN_CONTAINER := /root/go/pkg/mod
LIBDNF5_CACHE_IN_HOST := $(shell readlink -f ../../../var_cache_libdnf5)
WORKCOPY_IN_CONTAINER := /usr/local/src/cvmfs
NPROC ?= $(shell nproc)
#NPROC := 3
CMAKE_EXTRA_OPTS ?= ""

.PHONY: default debug clean wipe-build-image mrproper lint lint-fix shell.with-systemd
default: tests.done

debug:
	head -n1 ../../../_distros/${MY_DISTRO}/Dockerfile | sed s/:/_/ | grep "^FROM .*${MY_DISTRO}$$"
	@#echo ${MY_DISTRO}
	@#echo ${ENGINE}
	@#echo ${FLAVOUR}
	echo ${NETWORK}
	@#echo ${GIT_ORIGIN}
	@#echo ${GIT_BRANCH}
	@#echo ${IMAGE_NAME}

clean:
	rm -f *.done *.tests.FAILED

wipe-build-image:
	${ENGINE} stop ${CONTAINER_NAME} || true
	${ENGINE} rm ${CONTAINER_NAME} || true
	${ENGINE} image rm -f ${BUILD_IMAGE_NAME} || true
	rm -f build.done

wipe-build-except-externals: wipe-build-image
	cd cvmfs && git clean -dxf --exclude externals --exclude externals_build* --exclude externals_install*

mrproper:
	make clean
	make wipe-build-image
	${ENGINE} image rm -f ${IMAGE_NAME} || true
	rm -rf cvmfs
	@echo CCACHE IS LEFT INTACT

# TODO try also cvmfs/ci/run_tidy.sh
lint: build.done
	cp ../../../lint "${WORKCOPY_IN_HOST}"/
	${ENGINE} run --rm --name "${CONTAINER_NAME}-lint" -v "${WORKCOPY_IN_HOST}":"${WORKCOPY_IN_CONTAINER}" -v "${LIBDNF5_CACHE_IN_HOST}":/var/cache/libdnf5 --workdir "${WORKCOPY_IN_CONTAINER}" "${BUILD_IMAGE_NAME}" ./lint

lint-fix: build.done
	cp ../../../lint "${WORKCOPY_IN_HOST}"/
	${ENGINE} run --rm --name "${CONTAINER_NAME}-lint" -v "${WORKCOPY_IN_HOST}":"${WORKCOPY_IN_CONTAINER}" -v "${LIBDNF5_CACHE_IN_HOST}":/var/cache/libdnf5 --workdir "${WORKCOPY_IN_CONTAINER}" "${BUILD_IMAGE_NAME}" ./lint -fix

builder.image.done:
	if [[ ${ENGINE} == podman ]] && ! grep -q 'options overlay .*index=off' /etc/modprobe.d/overlay.conf; then echo "With podman, you may see errors like 'overlayfs: failed to verify upper' unless you use 'index=off' option with 'overlay' kernel module, see https://docs.oracle.com/en/operating-systems/uek/6/relnotes6.0/31025483.html"; exit 1; fi
	head -n1 ../../../_distros/${MY_DISTRO}/Dockerfile | sed s/:/_/ | grep "^FROM .*${MY_DISTRO}$$"
	cd ../../../_distros/${MY_DISTRO} && ${ENGINE} inspect "${IMAGE_NAME}" || ${ENGINE} build --network host . --tag "${IMAGE_NAME}"
	touch $@

cvmfs/cvmfs/cvmfs.cc:
	git clone ${GIT_ORIGIN} --branch ${GIT_BRANCH} --reference-if-able ${LOCAL_GIT_STORE} --dissociate cvmfs

CMAKE_COMPILER_OPTS ?= -DCMAKE_C_COMPILER=/usr/bin/clang -DCMAKE_CXX_COMPILER=/usr/bin/clang++
#CMAKE_COMPILER_OPTS ?= -DCMAKE_C_COMPILER=/usr/bin/gcc   -DCMAKE_CXX_COMPILER=/usr/bin/g++

build.done: builder.image.done cvmfs/cvmfs/cvmfs.cc
	mkdir -p "${GO_PKG_MOD_IN_HOST}"
	${ENGINE} stop "${CONTAINER_NAME}" || true
	${ENGINE} rm "${CONTAINER_NAME}" || true
	${ENGINE} run --detach --pids-limit=-1 --name "${CONTAINER_NAME}" -v "${WORKCOPY_IN_HOST}":"${WORKCOPY_IN_CONTAINER}" -v "${CCACHE_IN_HOST}":"${CCACHE_IN_CONTAINER}" -v "${GO_PKG_MOD_IN_HOST}":"${GO_PKG_MOD_IN_CONTAINER}" "${IMAGE_NAME}" sleep inf
	${ENGINE} exec "${CONTAINER_NAME}" git config --global --add safe.directory "${WORKCOPY_IN_CONTAINER}"
	# "bash -l" to pick up ccache dir into PATH and use it in externals builds
	${ENGINE} exec --workdir "${WORKCOPY_IN_CONTAINER}" "${CONTAINER_NAME}"  bash -l -c "cmake  . -DCMAKE_EXPORT_COMPILE_COMMANDS=1 -DCMAKE_BUILD_TYPE=Debug -DBUILD_GEOAPI=no  -DBUILD_SERVER=yes -DBUILD_SERVER_DEBUG=yes -DBUILD_LIBCVMFS=yes -DBUILD_LIBCVMFS_CACHE=yes -DBUILD_SHRINKWRAP=yes -DBUILD_DUCC=no  -DBUILD_RECEIVER=yes -DBUILD_RECEIVER_DEBUG=yes -DBUILD_ZLIB_NG=ON -DCFLAGS="-DCVMFS_SUPPRESS_ASSERTS=1" -DBUILD_UNITTESTS=ON -DBUILD_UNITTESTS_DEBUG=ON -DBUILD_GATEWAY=yes ${CMAKE_COMPILER_OPTS} -DCMAKE_CXX_COMPILER_LAUNCHER=ccache -DCMAKE_C_COMPILER_LAUNCHER=ccache -DCMAKE_INSTALL_PREFIX:PATH=/usr  -DBUILD_UBENCHMARKS=no -DBUILD_STRESS_TESTS=yes -DBUILD_DOCUMENTATION=no -DBUILD_QC_TESTS=no -DBUILD_COVERAGE=no -DENABLE_ASAN=no -DBUILD_SNAPSHOTTER=yes -DBUILD_POSIX_TOOLS=yes ${CMAKE_EXTRA_OPTS}"
	${ENGINE} exec --workdir "${WORKCOPY_IN_CONTAINER}" "${CONTAINER_NAME}"  bash -c 'V=1 VERBOSE=1 make --jobs=${NPROC} install V=1 VERBOSE=1'
	${ENGINE} stop --time 0 "${CONTAINER_NAME}"
	${ENGINE} commit "${CONTAINER_NAME}" "${BUILD_IMAGE_NAME}"
	touch $@

packaged-install-deb.done: builder.image.done cvmfs/cvmfs/cvmfs.cc
	echo ${MY_DISTRO} | grep 'ubuntu\|debian'
	mkdir -p "${GO_PKG_MOD_IN_HOST}"
	${ENGINE} stop "${CONTAINER_NAME}" || true
	${ENGINE} rm "${CONTAINER_NAME}" || true
	${ENGINE} run --detach --pids-limit=-1 --name "${CONTAINER_NAME}" -v "${WORKCOPY_IN_HOST}":"${WORKCOPY_IN_CONTAINER}" -v "${CCACHE_IN_HOST}":"${CCACHE_IN_CONTAINER}" -v "${GO_PKG_MOD_IN_HOST}":"${GO_PKG_MOD_IN_CONTAINER}" "${IMAGE_NAME}" /sbin/init
	${ENGINE} exec "${CONTAINER_NAME}" git config --global --add safe.directory "${WORKCOPY_IN_CONTAINER}"
	# "bash -l" to pick up ccache dir into PATH and use it in externals builds
	${ENGINE} exec --workdir "${WORKCOPY_IN_CONTAINER}" "${CONTAINER_NAME}"  bash -l -x -c "mk-build-deps ./packaging/debian/cvmfs/control && apt install -y ./cvmfs-build-deps_*_all.deb && apt install -y apache2 libapache2-mod-wsgi-py3 && export CMAKE_CXX_COMPILER_LAUNCHER=ccache && export CVMFS_EXTERNALS_PREFIX=/usr/local/src/cvmfs/cvmfs_externals_install && mkdir /tmp/build-ubuntu /tmp/build-ubuntu-config && ./ci/build_package.sh \$$PWD /tmp/build-ubuntu-config cvmfs-config && ./ci/build_package.sh \$$PWD /tmp/build-ubuntu cvmfs && apt-get -y remove 'cvmfs*' && apt-get -y install /tmp/build-ubuntu*/*.deb && systemctl enable apache2"
	${ENGINE} stop --time 0 "${CONTAINER_NAME}"
	${ENGINE} commit "${CONTAINER_NAME}" "${PACKAGED_INSTALL_DEB_IMAGE_NAME}"
	touch $@

tests.done: unittests-parallel.done pooled.ci.done-and-toredown
	touch $@

# if testing upstream way, we need to launch systemd
ingestsql-test.with-systemd.done: build.done
	${ENGINE} rm -f "${CONTAINER_NAME}-with-systemd" || true
	cp ingestsql-test.with-systemd.bash "${WORKCOPY_IN_HOST}"/
	${ENGINE} run --detach --name "${CONTAINER_NAME}-with-systemd" --privileged --device=/dev/fuse --cap-add=SYS_PTRACE --tmpfs /cvmfs --tmpfs /var/spool/cvmfs -v "${WORKCOPY_IN_HOST}":"${WORKCOPY_IN_CONTAINER}" "${BUILD_IMAGE_NAME}" /sbin/init
	${ENGINE} exec --workdir "${WORKCOPY_IN_CONTAINER}" "${CONTAINER_NAME}-with-systemd" ./ingestsql-test.with-systemd.bash || touch ${CONTAINER_NAME}-with-systemd.tests.FAILED
	touch $@
	${ENGINE} cp "${CONTAINER_NAME}-with-systemd":/var/log/tests.logs.tar .
	zstd --rm -f tests.logs.tar
	if [[ -f ${CONTAINER_NAME}-with-systemd.tests.FAILED ]]; then echo "TESTS FAILED"; exit 1; fi
	# ^-- On tests failure, returns non-zero, but produces the target file. Re-runs will say "nothing to do".

